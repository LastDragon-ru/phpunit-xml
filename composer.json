{
  "name": "lastdragon-ru/phpunit-xml",
  "homepage": "https://github.com/LastDragon-ru/php-packages",
  "description": "PHPUnit XML / XML Schema assertions.",
  "readme": "README.md",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "phpunit",
    "php",
    "xml",
    "xml asserts",
    "xml assertions",
    "phpunit xml asserts",
    "phpunit xml assertions"
  ],
  "support": {
    "issues": "https://github.com/LastDragon-ru/php-packages/issues",
    "source": "https://github.com/LastDragon-ru/php-packages",
    "forum": "https://github.com/LastDragon-ru/php-packages/discussions"
  },
  "require": {
    "php": "^8.4|^8.5",
    "ext-libxml": "*",
    "ext-dom": "*",
    "ext-mbstring": "*",
    "ext-xmlreader": "*",
    "lastdragon-ru/path": "self.version",
    "lastdragon-ru/phpunit-extensions": "self.version",
    "phpunit/phpunit": "^12.5.8"
  },
  "autoload": {
    "psr-4": {
      "LastDragon_ru\\PhpUnit\\XML\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LastDragon_ru\\PhpUnit\\XML\\Docs\\": "docs/"
    },
    "exclude-from-classmap": [
      "docs/"
    ]
  },
  "conflict": {
    "thecodingmachine/safe": "<3.0.0"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
